package com.insurance.policy.entity;

import jakarta.persistence.*;
import lombok.*;

@Entity
@Table(name = "policies")
@Getter
@Setter
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class Policy {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    private Long customerId; // from customer service

    private String policyNumber;

    @Enumerated(EnumType.STRING)         // This Annotation tells How Enums will be stored in the database.
    private PolicyType policyType;       // @Enumerated(EnumType.ORDINAL), it will store as a number.
                                         // MOTOR --> 0
    @Enumerated(EnumType.STRING)         // HEALTH  --> 1  
    private PolicyCategory category;     // COMMERCIAL  --> 2

    private Double premiumAmount;

    private Double coverageAmount;

    private Integer tenureInYears;
}
